# =====================================================
# Variáveis de ambiente das Edge Functions do SDR
# Configure essas no Supabase (Project Settings > Edge Functions > Secrets)
# =====================================================

# --- Supabase (preenchido automaticamente pelo runtime, não precisa configurar) ---
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Z-API ---
ZAPI_INSTANCE_ID=cole_aqui_o_instance_id
ZAPI_TOKEN=cole_aqui_o_token
ZAPI_CLIENT_TOKEN=cole_aqui_o_client_token_de_seguranca

# --- Claude (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- Meta Lead Ads (LP do WordPress com form do Meta) ---
META_VERIFY_TOKEN=invente_uma_string_aleatoria_aqui
META_PAGE_ACCESS_TOKEN=cole_o_page_access_token_de_longa_duracao
META_APP_SECRET=cole_o_app_secret_do_seu_app_no_facebook_developers

# --- Configuração do escritório ---
NOME_ESCRITORIO=B&Z Advocacia
URL_PAINEL=https://seu-painel.lovable.app
ESCRITORIO_AREAS=trabalhista,civel,familia,sucessoes,empresarial,tributario,consultivo
