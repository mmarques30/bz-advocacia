{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src/lib/toast.ts",
    "src/lib/importCsv.ts",
    "src/components/shared/DataTable.tsx",
    "src/__tests__/**/*.ts",
    "src/__tests__/**/*.tsx",
    "supabase/functions/_shared/**/*.ts"
  ]
}
