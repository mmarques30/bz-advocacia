{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  // Whitelist-based strict check: apenas arquivos estaveis entram aqui,
  // para deixar o strict ganhar cobertura gradualmente sem travar o build.
  // Edge functions (Deno runtime) sao checadas pelo `deno check` da Supabase,
  // nao pelo tsc do frontend, entao ficam fora daqui.
  "include": [
    "src/lib/toast.ts",
    "src/lib/importCsv.ts",
    "src/lib/contratoUtils.ts",
    "src/lib/whatsappUtils.ts",
    "src/lib/categoriaDespesa.ts",
    "src/lib/queryGuards.ts",
    "src/components/shared/DataTable.tsx",
    "src/hooks/useVisaoGeralFinanceiro.ts",
    "src/integrations/supabase/client.ts",
    "src/vite-env.d.ts",
    "src/__tests__/**/*.ts",
    "src/__tests__/**/*.tsx"
  ]
}
